#!/usr/bin/env bash
set -euo pipefail

# testchimp-preamble-check
# - Designed to be safe to run in any repo (no secrets printed)
# - Best-effort: never blocks the session by default (exit 0), but prints blockers clearly

_say() { printf '%s\n' "$*"; }
_warn() { printf '%s\n' "$*" >&2; }

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export SKILL_DIR

# --- Skill update check (git-based; canonical source of truth) ---
LOCAL_VERSION=""
REMOTE_VERSION=""

if command -v node >/dev/null 2>&1 && [ -f "$SKILL_DIR/SKILL.md" ]; then
  LOCAL_VERSION="$(SKILL_MD="$SKILL_DIR/SKILL.md" node - <<'NODE' 2>/dev/null || true
const fs = require('fs');
const txt = fs.readFileSync(process.env.SKILL_MD, 'utf8');
const m = txt.match(/^\s*version:\s*([0-9]+\.[0-9]+\.[0-9]+)\s*$/m);
if (m) process.stdout.write(m[1]);
NODE
  )"
fi

if [ -d "$SKILL_DIR/.git" ]; then
  # Fetch is safe; if offline, continue.
  git -C "$SKILL_DIR" fetch origin main >/dev/null 2>&1 || true
  if command -v node >/dev/null 2>&1; then
    REMOTE_VERSION="$(SKILL_DIR="$SKILL_DIR" node - <<'NODE' 2>/dev/null || true
const { execSync } = require('child_process');
function parseVersion(txt) {
  const m = txt.match(/^\s*version:\s*([0-9]+\.[0-9]+\.[0-9]+)\s*$/m);
  return m ? m[1] : '';
}
let remote = '';
try { remote = execSync(`git -C "${process.env.SKILL_DIR}" show origin/main:SKILL.md`, { stdio: ['ignore','pipe','ignore'] }).toString('utf8'); } catch {}
process.stdout.write(parseVersion(remote));
NODE
    )"
  fi
fi

_say "TESTCHIMP_SKILL_LOCAL_VERSION: ${LOCAL_VERSION:-unknown}"
_say "TESTCHIMP_SKILL_REMOTE_VERSION: ${REMOTE_VERSION:-unknown}"

if command -v node >/dev/null 2>&1 && [ -n "${LOCAL_VERSION:-}" ] && [ -n "${REMOTE_VERSION:-}" ]; then
  node - "$LOCAL_VERSION" "$REMOTE_VERSION" <<'NODE' >/dev/null 2>&1 || true
const [a,b] = process.argv.slice(2);
function cmp(x,y){
  const pa=x.split('.').map(n=>parseInt(n,10));
  const pb=y.split('.').map(n=>parseInt(n,10));
  for(let i=0;i<3;i++){ if((pa[i]||0)!==(pb[i]||0)) return (pa[i]||0)-(pb[i]||0); }
  return 0;
}
process.exit(cmp(a,b) < 0 ? 10 : 0);
NODE
  if [ "${PIPESTATUS[0]}" -eq 10 ]; then
    _warn "UPGRADE_AVAILABLE: run: git -C \"$SKILL_DIR\" pull origin main"
  fi
fi

TOP=""
if command -v git >/dev/null 2>&1; then
  TOP="$(git rev-parse --show-toplevel 2>/dev/null || true)"
fi

# --- MCP config / TESTCHIMP_API_KEY discoverability (no printing) ---
# Heuristic: prefer repo-local Cursor MCP config if present.
MCP_JSON=""
if [ -n "${TOP:-}" ] && [ -f "$TOP/ui/.cursor/mcp.json" ]; then
  MCP_JSON="$TOP/ui/.cursor/mcp.json"
elif [ -n "${TOP:-}" ] && [ -f "$TOP/.cursor/mcp.json" ]; then
  MCP_JSON="$TOP/.cursor/mcp.json"
elif [ -f ".cursor/mcp.json" ]; then
  MCP_JSON=".cursor/mcp.json"
fi

if [ -n "${MCP_JSON:-}" ] && command -v node >/dev/null 2>&1; then
  _say "MCP_CONFIG: $MCP_JSON"
  HAS_KEY="$(MCP_JSON="$MCP_JSON" node - <<'NODE' 2>/dev/null || true
const fs=require('fs');
const p=process.env.MCP_JSON;
try{
  const j=JSON.parse(fs.readFileSync(p,'utf8'));
  const k=j?.mcpServers?.testchimp?.env?.TESTCHIMP_API_KEY;
  if (k && String(k).trim() && !/placeholder/i.test(String(k))) process.stdout.write('yes');
  else process.stdout.write('no');
}catch{ process.stdout.write('no'); }
NODE
  )"
  if [ "$HAS_KEY" = "yes" ]; then
    _say "TESTCHIMP_API_KEY: present (not printed)"
  else
    _warn "BLOCKER: TESTCHIMP_API_KEY missing/blank/placeholder in MCP config (reload MCP after setting)"
  fi
else
  _warn "WARN: MCP config not found or node missing (cannot verify TESTCHIMP_API_KEY)"
fi

exit 0
